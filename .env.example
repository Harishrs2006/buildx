# ─── App ───────────────────────────────────────────
NODE_ENV=development
API_PORT=4000
API_VERSION=v1
FRONTEND_URL=http://localhost:3000
API_URL=http://localhost:4000

# ─── Database ──────────────────────────────────────
DATABASE_URL="postgresql://buildx:buildx_dev@localhost:5432/buildx_db?schema=public"
DATABASE_DIRECT_URL="postgresql://buildx:buildx_dev@localhost:5432/buildx_db?schema=public"

# ─── Redis ─────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# ─── Clerk Authentication ──────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxx
CLERK_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding

# ─── Cloudinary ────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name

# ─── OpenAI ────────────────────────────────────────
OPENAI_API_KEY=sk-xxxxxxxxxxxx
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ─── Security ──────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_string_in_production
API_RATE_LIMIT_WINDOW_MS=900000
API_RATE_LIMIT_MAX=100

# ─── Email ─────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=noreply@buildx.com

# ─── AWS (Phase 8) ─────────────────────────────────
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
